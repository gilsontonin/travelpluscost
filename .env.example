# ─────────────────────────────────────────────────────────────────────────────
# travel-booking — environment template
# Copy to .env.local and fill in. .env.local is gitignored; this file is committed.
# Never paste real keys into this file (it ends up on camera + in git).
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Analytics (set on Netlify for production; leave blank in dev) ──
# GA4 Measurement ID (analytics.google.com → Admin → Data stream)
NEXT_PUBLIC_GA_ID=
# Search Console HTML-tag verification token (search.google.com/search-console → URL-prefix → HTML tag)
NEXT_PUBLIC_GSC_VERIFICATION=

# ── Feature flags (parked-engine pattern) ──
# affiliate = redirect to partner (no checkout, no liability). merchant = own checkout (later).
NEXT_PUBLIC_BOOKING_MODE=affiliate
# Flights vertical (Duffel). Keep false until the merchant phase.
NEXT_PUBLIC_FLIGHTS_ENABLED=false
# Payment SDK environment: "sandbox" (test cards, no charge) or "live" (REAL money).
# Keep "sandbox" until LiteAPI MoR is confirmed + Seller-of-Travel is sorted (docs/PRICING.md §6).
NEXT_PUBLIC_PAYMENT_ENV=sandbox

# ── LiteAPI (hotel content + live rates) ──
LITEAPI_KEY=
# Sandbox key — used for SAFE test bookings (no real charge). See docs/HANDOFF.md.
LITEAPI_SANDBOX=
LITEAPI_ENV=production
LITEAPI_BASE_URL=https://api.liteapi.travel/v3.0
# Booking flow (prebook/book/manage) is on a DIFFERENT host — only used in the merchant phase.
LITEAPI_BOOK_BASE_URL=https://book.liteapi.travel/v3.0
# Shared secret for the inbound webhook (dashboard → Developer tools → Webhooks → auth token).
# Set the SAME value here and in the LiteAPI dashboard; /api/webhooks/liteapi rejects mismatches.
LITEAPI_WEBHOOK_SECRET=

# ── Transactional email (Resend — booking confirmation / receipt) ──
# Free key at resend.com. Until a sending domain is verified, leave BOOKING_FROM_EMAIL unset:
# it defaults to onboarding@resend.dev, which can ONLY deliver to your own Resend account email
# (fine for sandbox testing). Set BOOKING_FROM_EMAIL once your domain is verified to email anyone.
RESEND_API_KEY=
BOOKING_FROM_EMAIL=

# ── Supabase (Postgres — hotel content store) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Typesense (search index) ──
# Server (admin / indexing):
TYPESENSE_HOST=
TYPESENSE_PORT=443
TYPESENSE_PROTOCOL=https
TYPESENSE_ADMIN_API_KEY=
# Browser (search-only — safe to expose):
NEXT_PUBLIC_TYPESENSE_HOST=
NEXT_PUBLIC_TYPESENSE_PORT=443
NEXT_PUBLIC_TYPESENSE_PROTOCOL=https
NEXT_PUBLIC_TYPESENSE_SEARCH_ONLY_KEY=

# ── Upstash Redis (live-rate cache) ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Affiliate (v1 monetization — Travelpayouts) ──
TRAVELPAYOUTS_MARKER=
TRAVELPAYOUTS_TOKEN=

# ── Duffel (flights, merchant phase — later) ──
DUFFEL_API_TOKEN=

# ── Blog content tooling (AI + photos — used by scripts/blog/*, loaded via --env-file=.env.local) ──
# Google AI Studio key → real semantic vectors for related-posts (gemini-embedding-001) + (later) PAA/freshness.
GEMINI_API_KEY=
# Anthropic key → the optional Fable/Opus editor pass.
ANTHROPIC_API_KEY=
# Photo sourcing for post covers (npm run blog:photo). Unsplash preferred; Pexels is the fallback.
UNSPLASH_ACCESS_KEY=
UNSPLASH_APPLICATION_ID=
UNSPLASH_SECRET_KEY=
PEXELS_API_KEY=
# fal.ai (optional AI image generation).
FAL_KEY=
