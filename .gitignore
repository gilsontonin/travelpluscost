# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but DO commit the template (no real secrets in it)
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local Netlify folder
.netlify

# generated at build (npm run sitemaps → scripts/gen-sitemaps.mjs); regenerated on every deploy.
# /public/sitemap-*.xml covers every versioned index (sitemap-v3.xml, sitemap-v4.xml, …).
/public/sitemaps/
/public/sitemap-*.xml

# local data snapshots / one-off exports (sitemap CSV dumps, screenshots) — not part of the build
/exports/

# DB safety backups (e.g. rows removed in a cleanup) — local restore artifacts, never deployed
/backups/
